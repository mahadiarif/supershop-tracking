# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/supershop_db
REDIS_URL=redis://localhost:6379

# MediaMTX
MEDIAMTX_API_URL=http://localhost:9997

# Cameras (RTSP URLs)
CAMERA_1_RTSP=rtsp://admin:pass@192.168.1.101:554/stream
CAMERA_2_RTSP=rtsp://admin:pass@192.168.1.102:554/stream
CAMERA_3_RTSP=rtsp://admin:pass@192.168.1.103:554/stream
CAMERA_4_RTSP=rtsp://admin:pass@192.168.1.104:554/stream
CAMERA_5_RTSP=rtsp://admin:pass@192.168.1.105:554/stream
CAMERA_6_RTSP=rtsp://admin:pass@192.168.1.106:554/stream
CAMERA_7_RTSP=rtsp://admin:pass@192.168.1.107:554/stream
CAMERA_8_RTSP=rtsp://admin:pass@192.168.1.108:554/stream

# Zones
ENTRANCE_ZONE_COORDS=[[0,0],[640,0],[640,200],[0,200]]
EXIT_ZONE_COORDS=[[0,400],[640,400],[640,480],[0,480]]
CHECKOUT_ZONE_COORDS=[[400,300],[640,300],[640,480],[400,480]]

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
REPORT_EMAIL_TO=boss@company.com,manager@company.com

# App
SNAPSHOT_DIR=snapshots
API_SECRET_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:5173

# Worker debug / model toggles
WORKER_DEBUG_CAMERA=4
WORKER_DEBUG_FORCE_VISIBLE_TRACKS=true
WORKER_ENABLE_ULTRALYTICS=false

# Worker / YOLO
YOLO_MODEL_PATH=models/yolov26.pt
YOLO_TRACKER_CONFIG=bytetrack.yaml
TRACKING_ENABLED=true
YOLO_CLASS_IDS=0,24,25,26,28
